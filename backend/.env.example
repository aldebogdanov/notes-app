DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/notes
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:5173
# Telegram bot token for note reminders (from @BotFather). Empty = channel disabled.
TELEGRAM_BOT_TOKEN=
# Background reminder loop (true in normal operation; tests disable it).
SCHEDULER_ENABLED=true
